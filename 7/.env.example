# AI Provider Configuration (choose one: openai, google, qwen, deepseek, zhipu, moonshot, doubao)
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini Configuration
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-1.5-flash

# 通义千问 (Qwen) Configuration
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-plus

# DeepSeek Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# 智谱AI (Zhipu) Configuration
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-flash

# 月之暗面 (Moonshot) Configuration
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_MODEL=moonshot-v1-8k

# 字节豆包 (Doubao) Configuration
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL=doubao-1-5-pro-250528

# Crawler Configuration
NEWS_SOURCE_URL=https://example-finance-site.com/news/roll
ROBOTS_TXT_URL=https://example-finance-site.com/robots.txt
USER_AGENTS_FILE=user_agents.txt

# Database Configuration
DB_PATH=financial_news.db

# Scheduler Configuration
FETCH_INTERVAL_MINUTES=15
REQUEST_DELAY_MIN=3
REQUEST_DELAY_MAX=7
MAX_NEWS_PER_RUN=20

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=news_crawler.log
